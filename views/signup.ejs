<%-include('partials/header')%>
<h1>Signup</h1>
<form action="/signup" method="POST">
	<label>Email</label>
	<input
		type="email"
		name="email"
		required
	>
	<div>
		<%=errors?errors.email:''%>
	</div>
	<br>
	<label>Password</label>
	<input
		type="password"
		name="password"
		required
	>
	<div>
		<%=errors?errors.password:''%>
	</div>
	<br>
	<button type="submit">
		Signup
	</button>
</form>
<p>
	Already have an account?
	<a href="/login">Login</a>
</p>
<%-include('partials/footer')%>